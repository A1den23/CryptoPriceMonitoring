# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Global Settings
DEBUG=false
TIMEZONE=Asia/Shanghai  # Timezone for timestamps (e.g., Asia/Shanghai, America/New_York, UTC)
WS_PING_INTERVAL_SECONDS=30
WS_PONG_TIMEOUT_SECONDS=10
WS_MESSAGE_TIMEOUT_SECONDS=120
BOT_HEARTBEAT_INTERVAL_SECONDS=30

# Volume Alert Settings (global default)
VOLUME_ALERT_COOLDOWN_SECONDS=60  # Cooldown between volume alerts (seconds)

# Volatility Alert Settings (global default)
VOLATILITY_ALERT_COOLDOWN_SECONDS=60  # Cooldown between volatility alerts (seconds)

# Milestone Alert Settings (global default)
MILESTONE_ALERT_COOLDOWN_SECONDS=600  # Cooldown between milestone alerts (seconds, 10 minutes)

# Stablecoin Depeg Monitor Settings
STABLECOIN_DEPEG_MONITOR_ENABLED=false  # Enable optional stablecoin depeg monitoring
STABLECOIN_DEPEG_TOP_N=20  # Number of top stablecoins to watch
STABLECOIN_DEPEG_THRESHOLD_PERCENT=5  # Alert outside ±5% around $1
STABLECOIN_DEPEG_POLL_INTERVAL_SECONDS=300  # Poll interval for DefiLlama snapshots
STABLECOIN_DEPEG_ALERT_COOLDOWN_SECONDS=3600  # Cooldown between repeated stablecoin alerts

# Coin List (comma-separated, determines which coins to load)
COIN_LIST=BTC,ETH,SOL

# BTC Configuration (relatively stable, lower threshold)
BTC_ENABLED=true
BTC_SYMBOL=BTCUSDT
BTC_INTEGER_THRESHOLD=2000
BTC_VOLATILITY_PERCENT=7.0
BTC_VOLATILITY_WINDOW_SECONDS=180
BTC_VOLUME_ALERT_MULTIPLIER=50.0

# ETH Configuration (medium volatility)
ETH_ENABLED=true
ETH_SYMBOL=ETHUSDT
ETH_INTEGER_THRESHOLD=200
ETH_VOLATILITY_PERCENT=7.0
ETH_VOLATILITY_WINDOW_SECONDS=180
ETH_VOLUME_ALERT_MULTIPLIER=50.0

# SOL Configuration (high volatility, higher threshold and shorter window)
SOL_ENABLED=true
SOL_SYMBOL=SOLUSDT
SOL_INTEGER_THRESHOLD=20
SOL_VOLATILITY_PERCENT=7.0
SOL_VOLATILITY_WINDOW_SECONDS=180
SOL_VOLUME_ALERT_MULTIPLIER=50.0
