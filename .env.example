# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Global Settings
DEBUG=false

# Volume Alert Settings (global default)
VOLUME_ALERT_COOLDOWN_SECONDS=60  # Cooldown between volume alerts (seconds)

# Volatility Alert Settings (global default)
VOLATILITY_ALERT_COOLDOWN_SECONDS=60  # Cooldown between volatility alerts (seconds)

# Milestone Alert Settings (global default)
MILESTONE_ALERT_COOLDOWN_SECONDS=600  # Cooldown between milestone alerts (seconds, 10 minutes)

# Coin List (comma-separated, determines which coins to load)
COIN_LIST=BTC,ETH,SOL,USD1

# BTC Configuration (relatively stable, lower threshold)
BTC_ENABLED=true
BTC_SYMBOL=BTCUSDT
BTC_INTEGER_THRESHOLD=1000
BTC_VOLATILITY_PERCENT=5.0
BTC_VOLATILITY_WINDOW_SECONDS=180
BTC_VOLUME_ALERT_MULTIPLIER=30.0

# ETH Configuration (medium volatility)
ETH_ENABLED=true
ETH_SYMBOL=ETHUSDT
ETH_INTEGER_THRESHOLD=100
ETH_VOLATILITY_PERCENT=7.0
ETH_VOLATILITY_WINDOW_SECONDS=180
ETH_VOLUME_ALERT_MULTIPLIER=30.0

# SOL Configuration (high volatility, higher threshold and shorter window)
SOL_ENABLED=true
SOL_SYMBOL=SOLUSDT
SOL_INTEGER_THRESHOLD=10
SOL_VOLATILITY_PERCENT=7.0
SOL_VOLATILITY_WINDOW_SECONDS=180
SOL_VOLUME_ALERT_MULTIPLIER=30.0

# USD1 Configuration (Stablecoin - low volatility expected)
USD1_ENABLED=true
USD1_SYMBOL=USD1USDT
USD1_INTEGER_THRESHOLD=0.0005
USD1_VOLATILITY_PERCENT=0.5
USD1_VOLATILITY_WINDOW_SECONDS=180
USD1_VOLUME_ALERT_MULTIPLIER=30.0
